# ===============================
# ビルド用ステージ（Node.js）
# ===============================
FROM node:20.9.0 AS node
# Node.js や Yarn を含むイメージとして利用

# ===============================
# ビルド用ステージ（MeCab + mecab-ipadic-neologd）
# ===============================
FROM debian:latest AS mecab_builder
# このステージでは、必要なパッケージのインストール、辞書のコピー、
# mecab-ipadic-neologd のクローンとインストール、及び初期設定を行う

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates wget curl git build-essential \
      mecab libmecab-dev mecab-ipadic \
      patch pkg-config xz-utils perl procps unzip sed file && \
    update-ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# 既存の mecab-ipadic 辞書（UTF-8版）があれば /usr/lib/mecab/dic にコピー
RUN if [ -d /usr/share/mecab/dic/mecab-ipadic ]; then \
      mkdir -p /usr/lib/mecab/dic && \
      cp -r /usr/share/mecab/dic/mecab-ipadic /usr/lib/mecab/dic/; \
    fi

# 初期の mecabrc を標準辞書（mecab-ipadic）のパスに設定
RUN echo "dicdir = /usr/lib/mecab/dic/mecab-ipadic" > /etc/mecabrc

WORKDIR /usr/local/src

# mecab-ipadic-neologd のクローンおよび不要な sudo コマンドの削除（root 実行のため不要）
RUN git clone --depth 1 https://github.com/neologd/mecab-ipadic-neologd.git && \
    find /usr/local/src/mecab-ipadic-neologd -type f -exec sed -i 's/sudo //g' {} +

# mecab-ipadic-neologd のインストール
RUN mkdir -p /usr/lib/mecab/dic && \
    cd /usr/local/src/mecab-ipadic-neologd && \
    ./bin/install-mecab-ipadic-neologd -n -y -a -p /usr/lib/mecab/dic/mecab-ipadic-neologd

# mecabrc を neologd 用に上書き
RUN echo "dicdir = /usr/lib/mecab/dic/mecab-ipadic-neologd" > /etc/mecabrc

# ===============================
# ビルド用ステージ（MeCab-Ruby）
# ===============================
FROM ruby:3.2 AS mecab_ruby_builder
# このステージでは、公式リリースの mecab-ruby をダウンロードしビルド・インストールする

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget curl git build-essential ruby-dev \
    mecab libmecab-dev pkg-config && \
    update-ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /usr/local/src

RUN wget -q https://github.com/shogo82148/mecab/releases/download/v0.996.10/mecab-ruby-0.996.10.tar.gz && \
    tar zxvf mecab-ruby-0.996.10.tar.gz && \
    cd mecab-ruby-0.996.10 && \
    ruby extconf.rb --with-mecab-config=/usr/bin/mecab-config && \
    make && \
    make install
RUN find /usr/local/lib/ruby -name "MeCab.so"
# ※ ビルドログによると、拡張ライブラリ "MeCab.so" は
#     /usr/local/lib/ruby/site_ruby/3.2.0/x86_64-linux にインストールされています。

# ===============================
# ビルド用ステージ（HTS Engine + Open JTalk）
# ===============================
FROM debian AS openjtalk_builder
# このステージでは、HTS Engine と Open JTalk のソースを取得し、並列ビルドでインストールする

RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates wget curl git build-essential && \
    update-ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /usr/local/src

# Open JTalk と HTS Engine のソースをダウンロード
RUN wget -q --retry-connrefused --waitretry=2 --tries=5 -O hts_engine_API-1.08.tar.gz \
      "http://downloads.sourceforge.net/hts-engine/hts_engine_API-1.08.tar.gz" && \
    wget -q --retry-connrefused --waitretry=2 --tries=5 -O open_jtalk-1.07.tar.gz \
      "http://downloads.sourceforge.net/open-jtalk/open_jtalk-1.07.tar.gz"

# HTS Engine のビルドとインストール
RUN tar xf hts_engine_API-1.08.tar.gz && cd hts_engine_API-1.08 && \
    wget -O config.guess 'https://git.savannah.gnu.org/cgit/config.git/plain/config.guess' && \
    wget -O config.sub 'https://git.savannah.gnu.org/cgit/config.git/plain/config.sub' && \
    chmod +x config.guess config.sub && \
    ./configure --build=x86_64-pc-linux-gnu && \
    make -j$(nproc) && make install

# Open JTalk のビルドとインストール
RUN cd /usr/local/src && tar xf open_jtalk-1.07.tar.gz && cd open_jtalk-1.07 && \
    wget -O config.guess 'https://git.savannah.gnu.org/cgit/config.git/plain/config.guess' && \
    wget -O config.sub 'https://git.savannah.gnu.org/cgit/config.git/plain/config.sub' && \
    chmod +x config.guess config.sub && \
    sed -i "s/#define MAXBUFLEN 1024/#define MAXBUFLEN 10240/" bin/open_jtalk.c && \
    sed -i "s/0x00D0 SPACE/0x000D SPACE/" mecab-naist-jdic/char.def && \
    ./configure --build=x86_64-pc-linux-gnu --with-charset=UTF-8 && \
    make -j$(nproc) && make install

# ===============================
# 実行用ステージ（Shirasagi + MeCab + Open JTalk）
# ===============================
FROM ruby:3.2 AS runtime
# 必要なパッケージのインストール
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget mecab libmecab-dev pkg-config lame sox && \
    update-ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /var/www/shirasagi

# 必要なサンプル設定ファイルの配置
RUN cd /var/www/shirasagi/config && \
    mkdir -p samples && \
    find samples -type f \( -name "*.rb" -o -name "*.yml" \) -exec cp -n {} . \; || true

# node ステージから Yarn と Node のコピー
COPY --from=node /opt/yarn-* /opt/yarn
COPY --from=node /usr/local/bin/node /usr/local/bin/
COPY --from=node /usr/local/lib/node_modules/ /usr/local/lib/node_modules/
RUN ln -fs /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm && \
    ln -fs /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npx && \
    ln -fs /usr/local/lib/node /usr/local/bin/nodejs && \
    ln -fs /opt/yarn/bin/yarn /usr/local/bin/yarn && \
    ln -fs /opt/yarn/bin/yarn /usr/local/bin/yarnpkg

# MeCab 関連ファイルのコピー
COPY --from=mecab_builder /usr/local /usr/local
COPY --from=mecab_builder /usr/lib /usr/lib
COPY --from=mecab_builder /etc/mecabrc /etc/mecabrc

# → 修正: mecab-ruby のインストールされた site_ruby 全体をコピー
COPY --from=mecab_ruby_builder /usr/local/lib/ruby/site_ruby/ /usr/local/lib/ruby/site_ruby/

# Open JTalk 関連バイナリのコピー
COPY --from=openjtalk_builder /usr/local /usr/local

# 環境変数の設定
ENV PKG_CONFIG_PATH=/usr/lib/pkgconfig:$PKG_CONFIG_PATH
ENV RUBYLIB=/usr/local/lib/ruby/site_ruby

CMD ["bash"]
